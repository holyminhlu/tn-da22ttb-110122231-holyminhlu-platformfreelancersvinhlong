# =============================================================================
# Vĩnh Long Connected — biến môi trường (copy thành `.env` ở thư mục gốc dự án)
# =============================================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/vl_connected

# --- Backend API ---
PORT=5000
FRONTEND_URL=http://localhost:3000

# --- JWT (bắt buộc cho đăng nhập email & Google) ---
# Tạo chuỗi ngẫu nhiên dài, ví dụ: openssl rand -base64 48
JWT_ACCESS_SECRET=thay-bang-chuoi-bi-mat-access
JWT_REFRESH_SECRET=thay-bang-chuoi-bi-mat-refresh
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# --- Google OAuth (Google Cloud Console → APIs & Services → Credentials) ---
# 1. Tạo OAuth 2.0 Client ID (Web application)
# 2. Authorized JavaScript origins: http://localhost:3000
# 3. Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# --- Next.js (frontend gọi API) ---
NEXT_PUBLIC_API_URL=http://localhost:5000
