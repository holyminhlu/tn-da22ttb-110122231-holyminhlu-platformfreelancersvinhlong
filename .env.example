# =============================================================================
# VL Connected — Docker environment (copy to .env before: docker compose up)
# =============================================================================

# --- PostgreSQL (service: db) ---
POSTGRES_DB=vl_connected
POSTGRES_USER=vl_user
POSTGRES_PASSWORD=change_me_strong_password

# --- Backend database connection ---
DB_HOST=db
DB_PORT=5432
DB_NAME=vl_connected
DB_USER=vl_user
DB_PASSWORD=change_me_strong_password

# --- URLs (browser must reach API at NEXT_PUBLIC_API_URL from host machine) ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
API_PUBLIC_URL=http://localhost:5000

# --- JWT (required — change in production) ---
JWT_ACCESS_SECRET=change_me_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# --- Google Maps (optional) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- payOS payments (optional) ---
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_URL=http://localhost:5000/api/payments/payos-webhook
PAYOS_PAYOUT_WEBHOOK_URL=http://localhost:5000/api/payments/payos-payout-webhook

# --- Gemini AI (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- App tuning ---
PORT=5000
WORKFLOW_SLA_CRON=1
WORKFLOW_SLA_TICK_MS=3600000

# --- Published ports on host (optional overrides) ---
FRONTEND_PORT=3000
BACKEND_PORT=5000
POSTGRES_PORT=5432

