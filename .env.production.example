# =============================================================================
# VL Connected — Production template (minhlu.app)
# Sao chép thành .env trên server — KHÔNG commit file .env chứa secret thật.
#   cp .env.production.example .env
# =============================================================================

# --- PostgreSQL (service: db) ---
POSTGRES_DB=vl_connected
POSTGRES_USER=vl_user
POSTGRES_PASSWORD=change_me_strong_password

# --- Backend database connection ---
DB_HOST=db
DB_PORT=5432
DB_NAME=vl_connected
DB_USER=vl_user
DB_PASSWORD=change_me_strong_password

# --- URLs (trình duyệt phải gọi được NEXT_PUBLIC_API_URL) ---
FRONTEND_URL=https://minhlu.app
NEXT_PUBLIC_API_URL=https://minhlu.app
API_PUBLIC_URL=https://minhlu.app
INTERNAL_API_URL=http://backend:5000

# --- JWT (production — tạo chuỗi ngẫu nhiên ≥ 32 ký tự) ---
JWT_ACCESS_SECRET=change_me_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# --- Google OAuth (tạo mới secret sau khi bị lộ — Google Cloud Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://minhlu.app/api/auth/google/callback

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- payOS ---
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_URL=https://minhlu.app/api/payments/payos-webhook
PAYOS_PAYOUT_WEBHOOK_URL=https://minhlu.app/api/payments/payos-payout-webhook

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- App tuning ---
PORT=5000
WORKFLOW_SLA_CRON=1
WORKFLOW_SLA_TICK_MS=3600000

# --- Published ports (chỉ frontend/backend; không expose DB ra internet) ---
FRONTEND_PORT=3000
BACKEND_PORT=5000
