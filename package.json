{
  "name": "vl-connected",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npx kill-port 3000 5000",
    "dev": "concurrently -n FE,BE \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "next dev --port 3000",
    "dev:be": "npm --prefix backend run start:dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "kill-port": "^2.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
