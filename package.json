{
  "name": "vl-connected",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-dev-ports.mjs",
    "dev": "concurrently -n FE,BE \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "next dev --port 3000",
    "dev:be": "npm --prefix backend run start:dev",
    "build": "next build",
    "start": "next start",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-credit-cards-2": "^1.2.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-payment-inputs": "^1.2.0",
    "shadcn": "^4.7.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.65.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
